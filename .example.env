# Test secrets / opt-in flags. Copy to `.env` and fill in real values.
# `.env` is gitignored; this `.example.env` template is committed.

# Live Lodestone integration tests — set both to enable.
# World name must be the English server name (e.g. Phoenix, Lich, Twintania, Cerberus).
LODESTONE_TEST_NAME=Your Character Name
LODESTONE_TEST_WORLD=Phoenix
